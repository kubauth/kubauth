ete\" hidden\u003e\u003c/span\u003e\u0027);\n                };\n                xhr.onabort \u003d function () {\n                    console.log(\"implicit submit abort\")\n                };\n                xhr.ontimeout \u003d function () {\n                    console.log(\"implicit submit timeout\")\n                };\n                return xhr;\n            }\n\n            var xhr \u003d createxhr();\n            xhr.onerror \u003d function () {\n                console.log(\"implicit submit error (trying again in 2 seconds): \" + xhr.status + \" \" + xhr.responseText);\n                // workaround for https://gitlab.com/openid/conformance-suite/-/issues/1458\n                clearTimeout(timeoutId);\n                timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n                setTimeout(function() {\n                    newxhr \u003d createxhr();\n                    newxhr.onerror \u003d function () {\n                        console.log(\"second implicit submit error: \" + xhr.status + \" \" + xhr.responseText);\n                    }\n                }, 2000);\n                xhr.send(hash);\n            };\n            xhr.send(hash);\n        });\n    \u003c/script\u003e\n\n\n\u003c/body\u003e\n\u003c/html\u003e\n","response_content_type":"text/html","response_status_text":"200-","http":"response","response_status_code":200,"testId":"fqc87lEvPmmBYhL","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com"},"time":1777754796119},{"_id":"fqc87lEvPmmBYhL-d1vUNip7CYpiqfN4GzGom1MWC0Wh1PEU","msg":"Skipping optional task due to URL mismatch","task":"Submit kubauth login form","browser":"skip","match":"https://kubauth-oidc-server.kubauth-system.svc*/oauth2/login*","url":"https://localhost.emobix.co.uk:8443/test/a/kubauth-oidcc-basic/callback?error\u003dinvalid_scope\u0026error_description\u003dThe+requested+scope+is+invalid%2C+unknown%2C+or+malformed.+The+OAuth+2.0+Client+is+not+allowed+to+request+scope+%27p