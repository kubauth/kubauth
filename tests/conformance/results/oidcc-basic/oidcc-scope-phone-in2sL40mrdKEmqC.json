nformance-suite/-/issues/766 activated - assuming post has completed as 5 seconds have elapsed\")\n            // add a hidden tag so that Selenium can detect we\u0027re done processing\n\n            document.getElementById(\u0027complete\u0027).insertAdjacentHTML(\u0027beforeend\u0027, \u0027\u003cspan id\u003d\"submission_complete\" hidden\u003e\u003c/span\u003e\u0027);\n        }\n\n        document.addEventListener(\"DOMContentLoaded\", () \u003d\u003e {\n\n            var hash \u003d window.location.hash;\n\n            var returnUrl \u003d \"\\/log-detail.html?log\u003din2sL40mrdKEmqC\";\n\n            // workaround https://gitlab.com/openid/conformance-suite/-/issues/766 by assuming that the post completes\n            // after 5 seconds\n            var timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n\n            function createxhr() {\n                var xhr \u003d new XMLHttpRequest();\n                xhr.open(\u0027POST\u0027, \"https:\\/\\/localhost.emobix.co.uk:8443\\/test\\/a\\/kubauth-oidcc-basic\\/implicit\\/69Pycvq74ZcGgCKS85YG\", true);\n                xhr.setRequestHeader(\u0027Content-type\u0027, \u0027text/plain\u0027);\n                xhr.onload \u003d function () {\n                    submitComplete \u003d true;\n                    document.querySelector(\u0027#complete a\u0027).setAttribute(\"href\", returnUrl);\n                    document.getElementById(\u0027complete\u0027).classList.add(\u0027show\u0027);\n                    // add a hidden tag so that Selenium can detect we\u0027re done processing\n                    document.getElementById(\u0027complete\u0027).insertAdjacentHTML(\u0027beforeend\u0027, \u0027\u003cspan id\u003d\"submission_complete\" hidden\u003e\u003c/span\u003e\u0027);\n                };\n                xhr.onabort \u003d function () {\n                    console.log(\"implicit submit abort\")\n                };\n                xhr.ontimeout \u003d function () {\n                    console.log(\"implicit submit timeout\")\n                };\n                return xhr;\n            }\n\n            var xhr \u003d createxhr();\n            xhr.onerror \u003d function () {\n                console.log(\"implicit submit error (trying again in 2 seconds): \" + xhr.status + \" \" + xhr.responseText);\n                // workaround for https://gitlab.com/openid/conformance-suite/-/issues/1458\n                clearTimeout(timeoutId);\n                timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n                setTimeout(function() {\n                    newxhr \u003d createxhr();\n                    newxhr.onerror \u003d function () {\n                        console.log(\"second implicit submit error: \" + xhr.status + \" \" + xhr.responseText);\n                    }\n                }, 2000);\n                xhr.send(hash);\n            };\n            xhr.send(hash);\n        });\n    \u003c/script\u003e\n\n\n\u003c/body\u003e\n\u003c/html\u003e\n","response_content_type":"text/html","response_status_text":"200-","http":"response","response_status_code":200,"testId":"in2sL40mrdKEmqC","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com"},"time":1777723390652},{"_id":"in2sL40mrdKEmqC-BuyUgnZlEawoEEL8nvggNIz3jhUHJbp4","msg":"Unexpected URL for non-optional task","result":"FAILURE","task":"Submit kubauth login form","match":"https://kubauth-oidc-server.kubauth-system.svc*/oauth2/login*","url":"https://localhost.emobix.co.uk:8443/test/a/kubauth-oidcc-basic/callback?error\u003dinvalid_scope\u0026error_description\u003dThe+requested+scope+is+invalid%2C+unknown%2C+or+malformed.+The+OAuth+2.0+Client+is+not+allowed+to+request+scope+%27phone%27.\u0026state\u003dsaVxysagA7","commands":[["text","id","login","alice"],["text","id","password","alice-password"],["click","css","button[type\u003dsubmit]"]],"testId":"in2sL40mrdKEmqC","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com