ent to the test framework for further processing.\" data-bs-placement\u003d\"right\"\u003e\u003c/span\u003e\u003c/sup\u003e\u003c/h2\u003e\n                \u003cp id\u003d\"complete\" class\u003d\"bg-info collapse\"\u003eThe response has been sent to the server for processing. You may return to \u003ca href\u003d\"\" class\u003d\"link-primary\"\u003ethe test results page.\u003c/a\u003e\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n    \u003c!-- Include all compiled plugins (below), or include individual files as needed --\u003e\n    \u003c!-- Popper (necessary for Bootstrap\u0027s tooltips) --\u003e\n    \u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js\" integrity\u003d\"sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r\" crossorigin\u003d\"anonymous\"\u003e\u003c/script\u003e\n    \u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js\"\nintegrity\u003d\"sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy\" crossorigin\u003d\"anonymous\"\u003e\u003c/script\u003e\n\n    \u003cfooter class\u003d\"pageFooter\"\u003e\n        \u003cspan class\u003d\"muted\"\u003eOpenID Foundation conformance suite\u003c/span\u003e\n    \u003c/footer\u003e\n\n    \u003cscript type\u003d\"text/javascript\"\u003e\n        var submitComplete \u003d false;\n        function assumeComplete() {\n            if (submitComplete) {\n                return;\n            }\n            console.log(\"assumeComplete workaround for https://gitlab.com/openid/conformance-suite/-/issues/766 activated - assuming post has completed as 5 seconds have elapsed\")\n            // add a hidden tag so that Selenium can detect we\u0027re done processing\n\n            document.getElementById(\u0027complete\u0027).insertAdjacentHTML(\u0027beforeend\u0027, \u0027\u003cspan id\u003d\"submission_complete\" hidden\u003e\u003c/span\u003e\u0027);\n        }\n\n        document.addEventListener(\"DOMContentLoaded\", () \u003d\u003e {\n\n            var hash \u003d window.location.hash;\n\n            var returnUrl \u003d \"\\/log-detail.html?log\u003dgarmmxE8zCItwKv\";\n\n            // workaround https://gitlab.com/openid/conformance-suite/-/issues/766 by assuming that the post completes\n            // after 5 seconds\n            var timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n\n            function createxhr() {\n                var xhr \u003d new XMLHttpRequest();\n                xhr.open(\u0027POST\u0027, \"https:\\/\\/localhost.emobix.co.uk:8443\\/test\\/a\\/kubauth-oidcc-basic\\/implicit\\/aOUBau7P5YnuuQJCQk2S\", true);\n                xhr.setRequestHeader(\u0027Content-type\u0027, \u0027text/plain\u0027);\n                xhr.onload \u003d function () {\n                    submitComplete \u003d true;\n                    document.querySelector(\u0027#complete a\u0027).setAttribute(\"href\", returnUrl);\n                    document.getElementById(\u0027complete\u0027).classList.add(\u0027show\u0027);\n                    // add a hidden tag so that Selenium can detect we\u0027re done processing\n                    document.getElementById(\u0027complete\u0027).insertAdjacentHTML(\u0027beforeend\u0027, \u0027\u003cspan id\u003d\"submission_complete\" hidden\u003e\u003c/span\u003e\u0027);\n                };\n                xhr.onabort \u003d function () {\n                    console.log(\"implicit submit abort\")\n                };\n                xhr.ontimeout \u003d function () {\n                    console.log(\"implicit submit timeout\")\n                };\n                return xhr;\n            }\n\n            var xhr \u003d createxhr();\n            xhr.onerror \u003d function () {\n                console.log(\"implicit submit error (trying again in 2 seconds): \" + xhr.status + \" \" + xhr.responseText);\n                // workaround for https://gitlab.com/openid/conformance-suite/-/issues/1458\n                clearTimeout(timeoutId);\n                timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n                setTimeout(function() {\n                    newxhr \u003d createxhr();\n                    newxhr.onerror \u003d function () {\n                        console.log(\"second implicit submit error: \" + xhr.status + \" \" + xhr.responseText);\n                    }\n                }, 2000);\n                xhr.send(hash);\n            };\n            xhr.send(hash);\n        });\n    \u003c/script\u003e\n\n\n\u003c/body\u003e\n\u003c/html\u003e\n","response_content_type":"text/html","response_status_text":"200-","http":"response","response_status_code":200,"testId":"garmmxE8zCItwKv","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com"},"time":1777754745416},{"_id":"garmmxE8zCItwKv-cWcitbDmY2Kh1moNF7VqAMPl6Z0cAPtO","msg":"Skipping optional task due to URL mismatch","task":"Submit kubauth login form","browser":"skip","match":"https://kubauth-oidc-server.kubauth-system.svc*/oauth2/login*","url":"https://localhost.emobix.co.uk:8443/test/a/kubauth-oidcc-basic/callback?error\u003dunsupported_response_type\u0026error_description\u003dThe+authorization+server+does+not+support+obtaining+a+token+using+this+method.+%60The+request+is+missing+the+%27response_type%27+parameter.\u0026state\u003du8YAdLMkNq","commands":[["text","id","login","alice"],["text","id","password","alice-password"],["click","css","button[type\u003dsubmit]"]],"testId":"garmmxE8zCItwKv","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com"},"time":1777754745417},{"_id":"garmmxE8zCItwKv-9tXNJc36Ukj32fbxQDFv4Fc3lrCRkRSg","msg":"Incoming HTTP request to /test/a/kubauth-oidcc-basic/implicit/aOUBau7P5YnuuQJCQk2S","incoming_headers":{"host":"localhost.emobix.co.uk","x-forwarded-uri":"/test/a/kubauth-oidcc-basic/implicit/aOUBau7P5YnuuQJCQk2S","forwarded":"by\u003d127.0.0.1;for\u00