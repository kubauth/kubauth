n                    console.log(\"implicit submit timeout\")\n                };\n                return xhr;\n            }\n\n            var xhr \u003d createxhr();\n            xhr.onerror \u003d function () {\n                console.log(\"implicit submit error (trying again in 2 seconds): \" + xhr.status + \" \" + xhr.responseText);\n                // workaround for https://gitlab.com/openid/conformance-suite/-/issues/1458\n                clearTimeout(timeoutId);\n                timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n                setTimeout(function() {\n                    newxhr \u003d createxhr();\n                    newxhr.onerror \u003d function () {\n                        console.log(\"second implicit submit error: \" + xhr.status + \" \" + xhr.responseText);\n                    }\n                }, 2000);\n                xhr.send(hash);\n            };\n            xhr.send(hash);\n        });\n    \u003c/script\u003e\n\n\n\u003c/body\u003e\n\u003c/html\u003e\n","response_content_type":"text/html","response_status_text":"200-","http":"response","response_status_code":200,"testId":"SnHo2jtzTVznsex","src":"WebRunner","testOwner":{"sub":"developer","iss":"https://developer.com"},"time":1777723388502},{"_id":"SnHo2jtzTVznsex-6w6rBprRFpc8m8oUZC1wjwQgqnbhq1aI","msg":"Unexpected URL for non-optional task","result":"FAILURE","task":"Submit kubauth login form","match":"https://kubauth-oidc-server.kubauth-system.svc*/oauth2/login*","url":"https://localhost.emobix.co.uk:8443/test/a/kubauth-oidcc-basic/callback?error\u003dinvalid_scope\u0026error_description\u003dThe+requested+scope+is+invalid%2C+unknown%2C+or+malformed.+The+OAuth+2.0+Client+is+not+allowed+to+request+scope+%27address%27.\u0026state\u003dTdyut2wNrn","commands":[["text","id","login","alice"],["text","id","password","alice-password"],["click","css","button[type\u003dsubmit]"]],"testId":"SnHo2jtzTVznsex","src":"WebRunner","testOwner":{"sub":"developer","iss":"