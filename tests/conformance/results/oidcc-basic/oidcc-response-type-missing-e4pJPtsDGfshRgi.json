econds): \" + xhr.status + \" \" + xhr.responseText);\n                // workaround for https://gitlab.com/openid/conformance-suite/-/issues/1458\n                clearTimeout(timeoutId);\n                timeoutId \u003d setTimeout(function(){ assumeComplete(); }, 5000);\n                setTimeout(function() {\n                    newxhr \u003d createxhr();\n                    newxhr.onerror \u003d function () {\n                        console.log(\"second implicit submit error: \" + xhr.status + \" \" + xhr.responseText);\n                    }\n                }, 2000);\n                xhr.send(hash);\n            };\n            xhr.send(hash);\n        });\n    \r\n//]]\u003e\r\n    \u003c/script\u003e\r\n  \u003c/body\u003e\r\n\u003c/html\u003e\r\n","page_source":"\u003c?xml version\u003d\"1.0\" encoding\u003d\"UTF-8\"?\u003e\r\n\u003chtml lang\u003d\"en\" xmlns\u003d\"http://www.w3.org/1999/xhtml\"\u003e\r\n  \u003chead\u003e\r\n    \u003cmeta charset\u003d\"UTF-8\"/\u003e\r\n    \u003ctitle\u003e\r\n      OIDF Conformance: Processing Implicit Callback\r\n    \u003c/title\u003e\r\n    \u003c!-- Latest compiled and minified CSS --\u003e    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css\" integrity\u003d\"sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH\" crossorigin\u003d\"anonymous\"/\u003e\r\n    \u003c!-- Boostrap Icons --\u003e    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css\"/\u003e\r\n    \u003c!-- Optional theme --\u003e    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://fonts.googleapis.com/css?family\u003dPT+Sans\"/\u003e\r\n    \u003clink rel\u003d\"stylesheet\" type\u003d\"text/css\" href\u003d\"/css/layout.css\"/\u003e\r\n  \u003c/head\u003e\r\n  \u003cbody\u003e\r\n    \u003cdiv class\u003d\"pageHeader container-fluid\"\u003e\r\n      \u003cdiv class\u003d\"row\"\u