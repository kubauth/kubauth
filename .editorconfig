# EditorConfig — https://editorconfig.org
# Cross-editor whitespace baseline. The VS Code extension is in the devcontainer.
root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # markdown line breaks use trailing spaces
